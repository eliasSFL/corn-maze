# Bumpkin sprite sheet (idle / walk / dig / drill frames)
VITE_ANIMATION_URL=https://animations-dev.sunflower-land.com/

# Panel & label border images (PNG). Mainnet assets: https://sunflower-land.com/game-assets
VITE_IMAGE_BASE_URL=https://sunflower-land.com/testnet-assets

# Phaser tilesets / SFX / SUNNYSIDE CDN (falls back to VITE_IMAGE_BASE_URL when unset)
# VITE_PRIVATE_IMAGE_URL=https://sunflower-land.com/testnet-assets

# Shown on the portal loading overlay (optional)
# VITE_CLIENT_VERSION=dev

# Main Sunflower Land API (portal login POST /portal/:id/login, etc.)
# VITE_API_URL=https://api-dev.sunflower-land.com

# Minigames API Gateway — GET /data?type=session, POST /action, /animate/… (SST MinigamesApi URL)
# VITE_MINIGAMES_API_URL=https://xxxxxxxx.execute-api.region.amazonaws.com

# VITE_PORTAL_APP=your-portal-id
# VITE_PORTAL_GAME_URL=https://sunflower-land.com

# GAMEOVER ranged-mint token key (must match economy editor). Default 0 = bumpkin-hunter skulls.
# VITE_GAMEOVER_MINT_TOKEN_KEY=1
